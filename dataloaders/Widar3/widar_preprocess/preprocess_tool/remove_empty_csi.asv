function csi_clean = remove_empty_csi(csi_origin)
% 删除 cell 数组中空的 CSI 结构体
% 输入: csi_origin (cell 数组, 每个 cell 是 struct)
% 输出: csi_clean (清理后的 cell 数组)

    csi_clean = {};   % 初始化输出
    idx = 1;          % 输出索引
    deleted_count = 0; % 记录删除的 csi 数量
    
    for pa = 1:length(csi_origin)
        if isempty(csi_origin{pa})
            % 如果 cell 是空，跳过
            deleted_count = deleted_count + 1; 
            continue;
        end
        
        % 判断是否存在字段 csi 且非空
        if isfield(csi_origin{pa}, 'csi') && ~isempty(csi_origin{pa}.csi)
            csi_clean{idx,1} = csi_origin{pa}; %#ok<AGROW>
            idx = idx + 1;
        else
            deleted_count = deleted_count + 1; % 记录删除的数量
        end
    end
    
    % 输出删除的 csi 总数
    if deleted_count>0
        fprintf('已删除 %d 个空的 csi 结构体\n', deleted_count);
    end
end
